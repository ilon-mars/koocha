    "@vitest/eslint-plugin": "1.6.17",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "commitizen": "4.3.1",
    "cz-git": "1.13.1",
    "date-fns": "^4.1.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "~1.63.0",
    "eslint-plugin-playwright": "2.10.2",
    "eslint-plugin-vue": "~10.9.1",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.48.0",
    "oxlint": "~1.63.0",
